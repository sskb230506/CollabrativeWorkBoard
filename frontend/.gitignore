# ─────────────────────────────────────────────────────────────────────────────
# Frontend .gitignore — React / Vite / TypeScript / TailwindCSS
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Output ──────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Vite ──────────────────────────────────────────────────────────────────────
.vite/

# ── Environment & Secrets ─────────────────────────────────────────────────────
# Vite exposes VITE_* vars to the browser — never put secrets in these
# Keep .env.example as the template
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# ── Cache ─────────────────────────────────────────────────────────────────────
.cache/
.eslintcache
.parcel-cache/

# ── OS Artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# ── Storybook ─────────────────────────────────────────────────────────────────
storybook-static/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.zip
tmp/
temp/
