# ─────────────────────────────────────────────────────────────────────────────
# Root .env.example — CollaborativeWorkBoard Monorepo
#
# This file documents all environment variables used across the project.
# Copy this to .env and fill in your actual values.
# NEVER commit the real .env file — it is gitignored.
#
# Per-workspace env files live in:
#   backend/.env.example   → backend-specific variables
#   frontend/.env.example  → frontend-specific variables (VITE_* prefix)
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
