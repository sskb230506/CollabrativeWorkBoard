# ──────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ──────────────────────────────────────────────
# DATABASE (Neon PostgreSQL)
# DATABASE_URL: Pooled connection string (with -pooler suffix / pgbouncer) for runtime queries
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# DIRECT_URL: Direct, unpooled connection string for migrations and DDL commands
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

# ──────────────────────────────────────────────
# REDIS (Upstash)
# ──────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://YOUR_URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"

# BullMQ needs a raw Redis URL (Upstash supports it via TLS)
REDIS_URL="rediss://default:PASSWORD@HOST:6380"

# ──────────────────────────────────────────────
# AUTH
# ──────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ──────────────────────────────────────────────
# CLOUDINARY
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:5173,https://yourdomain.vercel.app"

# ──────────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ──────────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────────
LOG_LEVEL=debug
