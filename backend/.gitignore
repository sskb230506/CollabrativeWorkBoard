# ─────────────────────────────────────────────────────────────────────────────
# Backend .gitignore — Node.js / Express / TypeScript / Prisma
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Output ──────────────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── Environment & Secrets ─────────────────────────────────────────────────────
# Keep .env.example — it's the contract for required variables
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
.env.*.local

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Prisma ────────────────────────────────────────────────────────────────────
# The generated client lives in node_modules — never commit it
# The schema.prisma and migrations ARE tracked
# Generated migration SQL is tracked; migration lock IS tracked
# prisma/migrations/         ← DO track
# prisma/schema.prisma       ← DO track
# prisma/migrations/**/*.sql ← DO track

# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/

# ── Cache ─────────────────────────────────────────────────────────────────────
.cache/
.eslintcache

# ── OS Artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# ── Certificates & Keys ───────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.cert

# ── Misc ──────────────────────────────────────────────────────────────────────
tmp/
temp/
*.zip
